rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // User Validation
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200
        && data.streak is int && data.streak >= 0
        && data.totalXP is int && data.totalXP >= 0
        && data.completedLessons is int
        && data.keys().hasAll(['email', 'streak', 'totalXP'])
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    // Session Validation
    function isValidSession(data) {
      return data.type in ['hiragana', 'katakana', 'kanji']
        && data.score is int && data.score >= 0
        && data.totalItems is int && data.totalItems >= 0
        && data.timestamp is int
        && data.perfect is bool
        && data.keys().hasAll(['type', 'score', 'totalItems', 'timestamp', 'perfect']);
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().email == existing().email // Immutable email
        && incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'streak', 'totalXP', 'completedLessons', 'lastActive']);
      
      // User Sessions Sub-collection
      match /sessions/{sessionId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(sessionId) && isValidSession(incoming());
      }

      // User Materials Sub-collection
      match /materials/{materialId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(materialId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
